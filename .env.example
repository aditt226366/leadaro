# Copy this file to .env and fill in real values. .env is gitignored; never
# put real secrets in this template — it is committed.

# Host port 5433 — 5432 is occupied by the existing leadflow_postgres container.
DATABASE_URL=postgresql://leadaro:leadaro@localhost:5433/leadaro
JWT_SECRET=change-me-in-production

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Live per-turn model. Latency is dominated by fixed request overhead, not
# model size - see the measured table in the plan. Streaming is the lever.
LLM_MODEL=claude-sonnet-4-6

# ── LiveKit ──────────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# ── Speech ───────────────────────────────────────────────────────────────────
# ElevenLabs is used for voice cloning only; the call path runs entirely on
# Cartesia (STT ink-whisper + TTS sonic-3).
ELEVENLABS_API_KEY=your-elevenlabs-key
CARTESIA_API_KEY=your-cartesia-key

# ── Telephony (Plivo BYOC into LiveKit SIP) ──────────────────────────────────
PLIVO_AUTH_ID=your-plivo-auth-id
PLIVO_AUTH_TOKEN=your-plivo-auth-token
# LiveKit trunk IDs, written back by infra/setup_sip.py.
SIP_OUTBOUND_TRUNK_ID=
SIP_INBOUND_TRUNK_ID=
# India domestic calls must originate inside India (media anchoring).
SIP_DESTINATION_COUNTRY=in

# ── Integrations (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/integrations/google/callback

API_BASE_URL=http://localhost:8000
# Port 3001 — 3000 is occupied by the existing leadflow_frontend container.
WEB_BASE_URL=http://localhost:3001
